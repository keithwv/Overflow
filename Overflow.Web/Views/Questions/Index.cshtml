@model List<Overflow.Web.Models.QuestionViewModel>
@{
    ViewData["Title"] = "Questions";
    var selectedTag = ViewBag.SelectedTag as string;
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h1>
            @if (!string.IsNullOrEmpty(selectedTag))
            {
                <span>Questions tagged <span class="tag-badge">@selectedTag</span></span>
            }
            else
            {
                <span>All Questions</span>
            }
        </h1>
        <span class="text-muted small">@Model.Count question@(Model.Count == 1 ? "" : "s")</span>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon">💬</div>
        <p class="fw-semibold">No questions yet</p>
        <p class="text-muted">Be the first to ask a question!</p>
    </div>
}
else
{
    foreach (var question in Model)
    {
        <div class="question-item">
            <div class="d-flex gap-3">
                <div class="d-flex flex-column gap-1 flex-shrink-0">
                    <div class="question-stats">
                        <div class="stat @(question.Votes > 0 ? "" : "")">
                            <span class="stat-value">@question.Votes</span>
                            <span>votes</span>
                        </div>
                        <div class="stat @(question.HasAcceptedAnswer ? "has-accepted" : "")">
                            <span class="stat-value">@question.AnswerCount</span>
                            <span>answers</span>
                        </div>
                        <div class="stat">
                            <span class="stat-value">@question.ViewCount</span>
                            <span>views</span>
                        </div>
                    </div>
                </div>
                <div class="flex-grow-1 min-w-0">
                    <a class="question-title" asp-controller="Questions" asp-action="Details" asp-route-id="@question.Id">
                        @question.Title
                    </a>
                    <div class="mt-1 mb-1">
                        @foreach (var tag in question.TagSlugs)
                        {
                            <a class="tag-badge me-1" asp-controller="Questions" asp-action="Index" asp-route-tag="@tag">@tag</a>
                        }
                    </div>
                    <div class="question-meta">
                        Asked by <strong>@question.AskerDisplayName</strong>
                        &bull; @question.CreatedAt.ToString("MMM d, yyyy")
                    </div>
                </div>
            </div>
        </div>
    }
}
